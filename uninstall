#!/bin/bash
# uninstall
# Uninstalls the commit review hook from a git repository
# Safe and idempotent: removes only our section, preserves other hook content

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "======================================"
echo "  Commit Review Hook Uninstaller"
echo "======================================"
echo ""

# Check if we're in a git repository
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    echo -e "${RED}ERROR: Not in a git repository${NC}"
    echo "Please run this script from within a git repository."
    exit 1
fi

GIT_DIR=$(git rev-parse --git-dir)
HOOKS_DIR="${GIT_DIR}/hooks"
PRE_COMMIT_HOOK="${HOOKS_DIR}/pre-commit"
MARKER_BEGIN="# === Review Commit Hook BEGIN ==="
MARKER_END="# === Review Commit Hook END ==="

# Check if pre-commit hook exists
if [ ! -f "$PRE_COMMIT_HOOK" ]; then
    echo -e "${GREEN}✓ No pre-commit hook found (already clean)${NC}"
    exit 0
fi

# Check if our hook is installed
if ! grep -qF "$MARKER_BEGIN" "$PRE_COMMIT_HOOK" 2>/dev/null; then
    echo -e "${GREEN}✓ Review hook not installed in pre-commit (already clean)${NC}"
    exit 0
fi

# Extract INSTALL_PATH from the hook
INSTALL_PATH=$(grep "^# INSTALL_PATH=" "$PRE_COMMIT_HOOK" 2>/dev/null | head -1 | cut -d'=' -f2)

if [ -n "$INSTALL_PATH" ]; then
    echo "Installation path: ${INSTALL_PATH}"
    echo ""
fi

# Remove our section from pre-commit hook using sed
# This removes everything from MARKER_BEGIN to MARKER_END (inclusive)
TEMP_FILE=$(mktemp)
sed "/^${MARKER_BEGIN}$/,/^${MARKER_END}$/d" "$PRE_COMMIT_HOOK" > "$TEMP_FILE"

# Check if anything remains (excluding empty lines and comments)
REMAINING_CONTENT=$(grep -v '^[[:space:]]*$' "$TEMP_FILE" | grep -v '^[[:space:]]*#' || true)

if [ -z "$REMAINING_CONTENT" ]; then
    # Nothing left - remove the entire hook
    rm "$PRE_COMMIT_HOOK"
    rm "$TEMP_FILE"
    echo -e "${GREEN}✓ Removed pre-commit hook (was only our content)${NC}"
else
    # Something remains - keep the file without our section
    # Also remove trailing empty lines for cleanliness
    sed -i -e :a -e '/^[[:space:]]*$/d;N;ba' "$TEMP_FILE" 2>/dev/null || \
        perl -i -pe 'chomp if eof' "$TEMP_FILE"
    mv "$TEMP_FILE" "$PRE_COMMIT_HOOK"
    echo -e "${GREEN}✓ Removed review hook section from pre-commit (preserved other content)${NC}"
fi

# Delete installed files (idempotent - only if they exist)
if [ -n "$INSTALL_PATH" ]; then
    echo ""
    echo -e "${YELLOW}Removing installed files...${NC}"
    
    if [ -f "${INSTALL_PATH}/pre-commit-hook" ]; then
        rm "${INSTALL_PATH}/pre-commit-hook"
        echo "  ✓ Removed: ${INSTALL_PATH}/pre-commit-hook"
    fi
    
    if [ -f "${INSTALL_PATH}/request-review-to-user" ]; then
        rm "${INSTALL_PATH}/request-review-to-user"
        echo "  ✓ Removed: ${INSTALL_PATH}/request-review-to-user"
    fi
    
    if [ -f "${INSTALL_PATH}/strategy/1-ubuntu-zenity" ]; then
        rm "${INSTALL_PATH}/strategy/1-ubuntu-zenity"
        echo "  ✓ Removed: ${INSTALL_PATH}/strategy/1-ubuntu-zenity"
    fi
    
    if [ -f "${INSTALL_PATH}/strategy/2-universal-terminal" ]; then
        rm "${INSTALL_PATH}/strategy/2-universal-terminal"
        echo "  ✓ Removed: ${INSTALL_PATH}/strategy/2-universal-terminal"
    fi
    
    # Clean up empty directories
    STRATEGY_DIR="${INSTALL_PATH}/strategy"
    if [ -d "$STRATEGY_DIR" ]; then
        # Remove strategy directory if empty
        if [ -z "$(ls -A "$STRATEGY_DIR" 2>/dev/null)" ]; then
            rmdir "$STRATEGY_DIR"
            echo "  ✓ Removed empty directory: ${STRATEGY_DIR}"
        fi
    fi
    
    # Remove install directory if empty
    if [ -d "$INSTALL_PATH" ]; then
        if [ -z "$(ls -A "$INSTALL_PATH" 2>/dev/null)" ]; then
            rmdir "$INSTALL_PATH"
            echo "  ✓ Removed empty directory: ${INSTALL_PATH}"
        fi
    fi
fi

echo ""
echo -e "${GREEN}======================================"
echo "  Uninstallation Complete!"
echo "======================================${NC}"
echo ""
echo "The commit review hook has been removed."
echo ""
