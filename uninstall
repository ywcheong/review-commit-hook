#!/bin/bash
# uninstall
# Uninstalls the commit review hook from a git repository

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "======================================"
echo "  Commit Review Hook Uninstaller"
echo "======================================"
echo ""

# Check if we're in a git repository
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    echo -e "${RED}ERROR: Not in a git repository${NC}"
    echo "Please run this script from within a git repository."
    exit 1
fi

GIT_DIR=$(git rev-parse --git-dir)
HOOKS_DIR="${GIT_DIR}/hooks"
PRE_COMMIT_HOOK="${HOOKS_DIR}/pre-commit"

# Check if pre-commit hook exists
if [ ! -f "$PRE_COMMIT_HOOK" ]; then
    echo -e "${YELLOW}No pre-commit hook found. Nothing to uninstall.${NC}"
    exit 0
fi

# Extract INSTALL_PATH from the hook
INSTALL_PATH=$(grep "^# INSTALL_PATH=" "$PRE_COMMIT_HOOK" 2>/dev/null | cut -d'=' -f2)

if [ -z "$INSTALL_PATH" ]; then
    echo -e "${RED}ERROR: Could not find INSTALL_PATH in pre-commit hook${NC}"
    echo "The hook may have been modified or not installed correctly."
    exit 1
fi

echo "Installation path: ${INSTALL_PATH}"
echo ""

# Delete installed files
echo -e "${YELLOW}Removing installed files...${NC}"

if [ -f "${INSTALL_PATH}/pre-commit-hook" ]; then
    rm "${INSTALL_PATH}/pre-commit-hook"
    echo "  ✓ Removed: ${INSTALL_PATH}/pre-commit-hook"
fi

if [ -f "${INSTALL_PATH}/request-review-to-user" ]; then
    rm "${INSTALL_PATH}/request-review-to-user"
    echo "  ✓ Removed: ${INSTALL_PATH}/request-review-to-user"
fi

if [ -f "${INSTALL_PATH}/strategy/1-ubuntu-zenity" ]; then
    rm "${INSTALL_PATH}/strategy/1-ubuntu-zenity"
    echo "  ✓ Removed: ${INSTALL_PATH}/strategy/1-ubuntu-zenity"
fi

if [ -f "${INSTALL_PATH}/strategy/2-ubuntu-terminal" ]; then
    rm "${INSTALL_PATH}/strategy/2-ubuntu-terminal"
    echo "  ✓ Removed: ${INSTALL_PATH}/strategy/2-ubuntu-terminal"
fi

# Clean up empty directories
STRATEGY_DIR="${INSTALL_PATH}/strategy"
if [ -d "$STRATEGY_DIR" ]; then
    # Remove strategy directory if empty
    if [ -z "$(ls -A "$STRATEGY_DIR" 2>/dev/null)" ]; then
        rmdir "$STRATEGY_DIR"
        echo "  ✓ Removed empty directory: ${STRATEGY_DIR}"
    fi
fi

# Remove install directory if empty
if [ -d "$INSTALL_PATH" ]; then
    if [ -z "$(ls -A "$INSTALL_PATH" 2>/dev/null)" ]; then
        rmdir "$INSTALL_PATH"
        echo "  ✓ Removed empty directory: ${INSTALL_PATH}"
    fi
fi

echo ""

# Handle pre-commit hook
echo -e "${YELLOW}Cleaning up pre-commit hook...${NC}"

# Check if there's a backup
LATEST_BACKUP=$(ls -t "${HOOKS_DIR}/pre-commit.backup."* 2>/dev/null | head -1)

if [ -n "$LATEST_BACKUP" ]; then
    # Restore backup
    mv "$LATEST_BACKUP" "$PRE_COMMIT_HOOK"
    echo -e "${GREEN}✓ Restored original pre-commit hook from backup${NC}"
else
    # Remove our hook entirely
    rm "$PRE_COMMIT_HOOK"
    echo -e "${GREEN}✓ Removed pre-commit hook${NC}"
fi

echo ""
echo -e "${GREEN}======================================"
echo "  Uninstallation Complete!"
echo "======================================${NC}"
echo ""
echo "The commit review hook has been removed."
echo ""
