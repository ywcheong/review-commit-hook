#!/bin/bash
# install
# Installs the commit review hook into a git repository
# Safe and idempotent: appends to existing hooks instead of replacing

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "======================================"
echo "  Commit Review Hook Installer"
echo "======================================"
echo ""

# Check if we're in a git repository
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    echo -e "${RED}ERROR: Not in a git repository${NC}"
    echo "Please run this script from within a git repository."
    exit 1
fi

GIT_DIR=$(git rev-parse --git-dir)
HOOKS_DIR="${GIT_DIR}/hooks"
PROJECT_ROOT=$(git rev-parse --show-toplevel)
DEFAULT_TARGET="${PROJECT_ROOT}/utility/hook"

echo "Project: ${PROJECT_ROOT}"
echo "Hooks directory: ${HOOKS_DIR}"
echo ""

# Ask for installation directory
echo -e "${YELLOW}Where should the scripts be installed?${NC}"
read -p "Directory [${DEFAULT_TARGET}]: " TARGET_DIR
TARGET_DIR="${TARGET_DIR:-${DEFAULT_TARGET}}"

# Resolve to absolute path
if [[ "${TARGET_DIR}" != /* ]]; then
    TARGET_DIR="${PROJECT_ROOT}/${TARGET_DIR}"
fi

echo ""

# Step 1: Install scripts (idempotent - overwrites with same content)
mkdir -p "${TARGET_DIR}/strategy"

cp "${SCRIPT_DIR}/pre-commit-hook" "${TARGET_DIR}/pre-commit-hook"
cp "${SCRIPT_DIR}/request-review-to-user" "${TARGET_DIR}/request-review-to-user"
cp "${SCRIPT_DIR}/strategy/1-ubuntu-zenity" "${TARGET_DIR}/strategy/1-ubuntu-zenity"
cp "${SCRIPT_DIR}/strategy/2-universal-terminal" "${TARGET_DIR}/strategy/2-universal-terminal"

chmod +x "${TARGET_DIR}/pre-commit-hook"
chmod +x "${TARGET_DIR}/request-review-to-user"
chmod +x "${TARGET_DIR}/strategy/1-ubuntu-zenity"
chmod +x "${TARGET_DIR}/strategy/2-universal-terminal"
echo -e "${GREEN}✓ Scripts installed to ${TARGET_DIR}${NC}"
echo ""

# Step 2: Set up pre-commit hook (idempotent)
echo -e "${YELLOW}Step 2: Setting up pre-commit hook${NC}"

PRE_COMMIT_HOOK="${HOOKS_DIR}/pre-commit"
MARKER_BEGIN="# === Review Commit Hook BEGIN ==="
MARKER_END="# === Review Commit Hook END ==="

if [ -f "$PRE_COMMIT_HOOK" ]; then
    # Check if already installed (with same path)
    if grep -qF "# INSTALL_PATH=${TARGET_DIR}" "$PRE_COMMIT_HOOK" 2>/dev/null; then
        echo -e "${GREEN}✓ Pre-commit hook already configured (idempotent)${NC}"
    elif grep -qF "$MARKER_BEGIN" "$PRE_COMMIT_HOOK" 2>/dev/null; then
        # Different installation path exists
        echo -e "${YELLOW}Hook installed at different path. Remove first to reinstall.${NC}"
        grep "# INSTALL_PATH=" "$PRE_COMMIT_HOOK" || true
    else
        # Append our hook to existing script
        cat >> "$PRE_COMMIT_HOOK" << HOOK_EOF

$MARKER_BEGIN
# INSTALL_PATH=${TARGET_DIR}
# Do not modify this block - managed by review-commit-hook

# Run commit review (must be last)
if [ -x "${TARGET_DIR}/pre-commit-hook" ]; then
    "${TARGET_DIR}/pre-commit-hook"
    exit \$?
fi

exit 0
$MARKER_END
HOOK_EOF
        echo -e "${GREEN}✓ Appended to existing pre-commit hook${NC}"
    fi
else
    # Create new pre-commit hook
    cat > "$PRE_COMMIT_HOOK" << HOOK_EOF
#!/bin/bash
$MARKER_BEGIN
# INSTALL_PATH=${TARGET_DIR}
# Do not modify this block - managed by review-commit-hook

if [ -x "${TARGET_DIR}/pre-commit-hook" ]; then
    "${TARGET_DIR}/pre-commit-hook"
    exit \$?
fi

exit 0
$MARKER_END
HOOK_EOF
    chmod +x "$PRE_COMMIT_HOOK"
    echo -e "${GREEN}✓ Pre-commit hook created${NC}"
fi

echo ""
echo -e "${GREEN}======================================"
echo "  Installation Complete!"
echo "======================================${NC}"
echo ""
echo "Installed files:"
echo "  - ${TARGET_DIR}/pre-commit-hook"
echo "  - ${TARGET_DIR}/request-review-to-user"
echo "  - ${TARGET_DIR}/strategy/1-ubuntu-zenity"
echo "  - ${TARGET_DIR}/strategy/2-universal-terminal"
echo "  - ${PRE_COMMIT_HOOK}"
echo ""
echo "To uninstall:"
echo "  Run: ${SCRIPT_DIR}/uninstall"
echo ""
echo "To skip hook temporarily:"
echo "  git commit --no-verify -m \"message\""
echo ""
